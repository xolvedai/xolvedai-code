{
  "name": "xolvedai-code",
  "displayName": "XolvedAI Code",
  "publisher": "xolvedai",
  "version": "1.8.0",
  "description": "Premium xAI Grok-powered agent for full-stack GitHub app development. Multi-file batch editing, native tool calling, vision, approval workflows, Plan/Act mode. Powered by Grok 4.20-reasoning.",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Programming Languages", "Snippets", "Other"],
  "keywords": ["xai", "xolvedai", "grok", "agentic", "tool-calling", "vision", "cline", "multi-file", "fullstack", "github-app"],
  "icon": "assets/logo.png",
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/xolvedai/xolvedai-code.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "xolvedai-code.startChat",
        "title": "XolvedAI Code: Open Agent Chat"
      }
    ],
    "keybindings": [
      {
        "command": "xolvedai-code.startChat",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "XolvedAI Code",
      "properties": {
        "xolvedai-code.model": {
          "type": "string",
          "default": "grok-4.20-reasoning",
          "enum": ["grok-4.20-reasoning", "grok-4.20-non-reasoning", "grok-4-1-fast-reasoning"],
          "description": "Default Grok model"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xolvedai-code",
          "title": "XolvedAI Code",
          "icon": "assets/logo.png"
        }
      ]
    },
    "views": {
      "xolvedai-code": [
        {
          "id": "xolvedaiChatView",
          "name": "XolvedAI Agent Chat"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "openai": "^4.85.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.2.0"
  }
}