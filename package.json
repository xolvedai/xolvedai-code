{
  "name": "coding-intelligence-x-xolvedai",
  "displayName": "Coding Intelligence x XolvedAI",
  "publisher": "xolvedai",
  "version": "1.9.4",
  "description": "Premium xAI Grok-powered agent for full-stack GitHub app development.",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Programming Languages", "Snippets", "Other"],
  "keywords": ["xai", "xolvedai", "grok", "agentic", "tool-calling", "vision", "cline"],
  "icon": "assets/logo.png",
  "galleryBanner": { "color": "#0a0a0a", "theme": "dark" },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/xolvedai/xolvedai-code.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "coding-intelligence-x-xolvedai.startChat",
        "title": "Coding Intelligence x XolvedAI: Open Agent Chat"
      }
    ],
    "keybindings": [
      {
        "command": "coding-intelligence-x-xolvedai.startChat",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "Coding Intelligence x XolvedAI",
      "properties": {
        "coding-intelligence-x-xolvedai.model": {
          "type": "string",
          "default": "grok-4.20-reasoning",
          "enum": ["grok-4.20-reasoning", "grok-4.20-non-reasoning", "grok-4-1-fast-reasoning"],
          "description": "Default Grok model"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": { "openai": "^4.85.0" },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.2.0"
  }
}